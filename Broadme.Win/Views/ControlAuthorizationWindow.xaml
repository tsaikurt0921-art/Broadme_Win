<Window x:Class="Broadme.Win.Views.ControlAuthorizationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="控制授權"
        Width="900"
        Height="1360"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#F6F6F6">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#F6F6F6" BorderBrush="#DADADA" BorderThickness="0,0,0,1">
            <TextBlock Text="控制授權" FontSize="48" FontWeight="Bold" Foreground="#5E5E5E" VerticalAlignment="Center" Margin="160,0,0,0"/>
        </Border>

        <Grid Grid.Row="1" Margin="40,30,40,30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="22"/>
                <RowDefinition Height="1"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="控制授權" FontSize="66" FontWeight="Black" Foreground="#262C34" HorizontalAlignment="Center" Margin="0,40,0,0"/>
            <TextBlock Grid.Row="1" Text="請輸入控制端顯示的 PIN 碼" FontSize="58" Foreground="#7A7F84" HorizontalAlignment="Center" Margin="0,12,0,0"/>

            <UniformGrid Grid.Row="2" Columns="6" Margin="70,40,70,0">
                <TextBox x:Name="Pin1" MaxLength="1" FontSize="64" FontWeight="Bold" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Margin="8" Height="170" TextChanged="PinChanged" PreviewTextInput="PinTextInput" BorderBrush="#1B7FE6" BorderThickness="4" Background="#F6F6F6" />
                <TextBox x:Name="Pin2" MaxLength="1" FontSize="64" FontWeight="Bold" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Margin="8" Height="170" TextChanged="PinChanged" PreviewTextInput="PinTextInput" BorderBrush="#C8C8CC" BorderThickness="4" Background="#F6F6F6" />
                <TextBox x:Name="Pin3" MaxLength="1" FontSize="64" FontWeight="Bold" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Margin="8" Height="170" TextChanged="PinChanged" PreviewTextInput="PinTextInput" BorderBrush="#C8C8CC" BorderThickness="4" Background="#F6F6F6" />
                <TextBox x:Name="Pin4" MaxLength="1" FontSize="64" FontWeight="Bold" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Margin="8" Height="170" TextChanged="PinChanged" PreviewTextInput="PinTextInput" BorderBrush="#C8C8CC" BorderThickness="4" Background="#F6F6F6" />
                <TextBox x:Name="Pin5" MaxLength="1" FontSize="64" FontWeight="Bold" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Margin="8" Height="170" TextChanged="PinChanged" PreviewTextInput="PinTextInput" BorderBrush="#C8C8CC" BorderThickness="4" Background="#F6F6F6" />
                <TextBox x:Name="Pin6" MaxLength="1" FontSize="64" FontWeight="Bold" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Margin="8" Height="170" TextChanged="PinChanged" PreviewTextInput="PinTextInput" BorderBrush="#C8C8CC" BorderThickness="4" Background="#F6F6F6" />
            </UniformGrid>

            <Grid Grid.Row="3" Margin="120,28,120,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="34"/>
                    <ColumnDefinition Width="1.35*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="清除" Height="90" FontSize="52" Background="#E4E4E6" BorderBrush="#E4E4E6" Foreground="#1E2229" Click="ClearClick"/>
                <Button Grid.Column="2" x:Name="AuthButton" Content="✔  授權控制" Height="90" FontSize="52" Background="#9CB8E8" BorderBrush="#9CB8E8" Foreground="#F3F7FF" Click="AuthClick" IsEnabled="False"/>
            </Grid>

            <Border Grid.Row="4" Background="#DADADA"/>

            <TextBlock Grid.Row="5" Text="控制端網址" FontSize="42" Foreground="#8A8F95" HorizontalAlignment="Center" Margin="0,34,0,12"/>

            <Border Grid.Row="6" HorizontalAlignment="Center" Background="White" CornerRadius="12" Padding="12" BorderBrush="#E5E5E5" BorderThickness="1" Margin="0,0,0,18">
                <Image x:Name="QrImage" Width="340" Height="340" Stretch="Uniform"/>
            </Border>

            <StackPanel Grid.Row="7" HorizontalAlignment="Center">
                <TextBlock x:Name="ControlUrlText" FontSize="46" Foreground="#7A7F84" TextAlignment="Center" Margin="0,0,0,18"/>
                <TextBlock x:Name="StatusText" HorizontalAlignment="Center" Margin="0,0,0,8" FontSize="34"/>
                <TextBlock Text="ⓘ  掃描 QR Code 或開啟網址以控制" FontSize="38" Foreground="#7A7F84" HorizontalAlignment="Center"/>
                <TextBlock Text="⚠  授權後該控制端可進行遠端操作" FontSize="38" Foreground="#7A7F84" HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
