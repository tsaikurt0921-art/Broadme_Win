<Window x:Class="Broadme.Win.Views.ControlAuthorizationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="控制授權"
        Width="520"
        Height="780"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="#F6F6F6">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#F6F6F6" BorderBrush="#DADADA" BorderThickness="0,0,0,1">
            <TextBlock Text="控制授權" FontSize="24" FontWeight="Bold" Foreground="#5E5E5E" VerticalAlignment="Center" Margin="30,0,0,0"/>
        </Border>

        <Grid Grid.Row="1" Margin="20,15,20,15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="控制授權" FontSize="32" FontWeight="Black" Foreground="#262C34" HorizontalAlignment="Center" Margin="0,10,0,0"/>
            <TextBlock Grid.Row="1" Text="請輸入控制端顯示的 PIN 碼" FontSize="24" Foreground="#7A7F84" HorizontalAlignment="Center" Margin="0,8,0,0"/>

            <UniformGrid Grid.Row="2" Columns="6" Margin="30,20,30,0">
                <TextBox x:Name="Pin1" MaxLength="1" FontSize="32" FontWeight="Bold" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Margin="4" Height="70" TextChanged="PinChanged" PreviewTextInput="PinTextInput" BorderBrush="#1B7FE6" BorderThickness="3" Background="#F6F6F6" />
                <TextBox x:Name="Pin2" MaxLength="1" FontSize="32" FontWeight="Bold" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Margin="4" Height="70" TextChanged="PinChanged" PreviewTextInput="PinTextInput" BorderBrush="#C8C8CC" BorderThickness="3" Background="#F6F6F6" />
                <TextBox x:Name="Pin3" MaxLength="1" FontSize="32" FontWeight="Bold" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Margin="4" Height="70" TextChanged="PinChanged" PreviewTextInput="PinTextInput" BorderBrush="#C8C8CC" BorderThickness="3" Background="#F6F6F6" />
                <TextBox x:Name="Pin4" MaxLength="1" FontSize="32" FontWeight="Bold" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Margin="4" Height="70" TextChanged="PinChanged" PreviewTextInput="PinTextInput" BorderBrush="#C8C8CC" BorderThickness="3" Background="#F6F6F6" />
                <TextBox x:Name="Pin5" MaxLength="1" FontSize="32" FontWeight="Bold" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Margin="4" Height="70" TextChanged="PinChanged" PreviewTextInput="PinTextInput" BorderBrush="#C8C8CC" BorderThickness="3" Background="#F6F6F6" />
                <TextBox x:Name="Pin6" MaxLength="1" FontSize="32" FontWeight="Bold" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Margin="4" Height="70" TextChanged="PinChanged" PreviewTextInput="PinTextInput" BorderBrush="#C8C8CC" BorderThickness="3" Background="#F6F6F6" />
            </UniformGrid>

            <Grid Grid.Row="3" Margin="40,15,40,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="1.5*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="清除" Height="45" FontSize="20" Background="#E4E4E6" BorderBrush="#E4E4E6" Foreground="#1E2229" Click="ClearClick"/>
                <Button Grid.Column="2" x:Name="AuthButton" Content="✔  授權控制" Height="45" FontSize="20" Background="#9CB8E8" BorderBrush="#9CB8E8" Foreground="#F3F7FF" Click="AuthClick" IsEnabled="False"/>
            </Grid>

            <Separator Grid.Row="4" Margin="0,10" Background="#DADADA"/>

            <TextBlock Grid.Row="5" Text="控制端網址" FontSize="22" Foreground="#8A8F95" HorizontalAlignment="Center" Margin="0,10,0,8"/>

            <Border Grid.Row="6" HorizontalAlignment="Center" Background="White" CornerRadius="8" Padding="8" BorderBrush="#E5E5E5" BorderThickness="1" Margin="0,0,0,10">
                <Image x:Name="QrImage" Width="220" Height="220" Stretch="Uniform"/>
            </Border>

            <StackPanel Grid.Row="7" HorizontalAlignment="Center">
                <TextBlock x:Name="ControlUrlText" FontSize="20" Foreground="#7A7F84" TextAlignment="Center" Margin="0,0,0,10"/>
                <TextBlock x:Name="StatusText" HorizontalAlignment="Center" Margin="0,0,0,4" FontSize="18"/>
                <TextBlock Text="ⓘ  掃描 QR Code 或開啟網址以控制" FontSize="16" Foreground="#7A7F84" HorizontalAlignment="Center"/>
                <TextBlock Text="⚠  授權後該控制端可進行遠端操作" FontSize="16" Foreground="#7A7F84" HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
